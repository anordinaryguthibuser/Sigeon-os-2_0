rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for User entity presence documents
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'lastActive'])
        && data.keys().size() == 2
        && data.username is string
        && data.username.size() >= 2
        && data.username.size() <= 20
        && data.lastActive is timestamp;
    }

    // Validation for Message entity
    function isValidMessage(data) {
      return data.keys().hasAll(['username', 'text', 'timestamp'])
        && data.keys().size() == 3
        && data.username is string
        && data.username.size() >= 2
        && data.username.size() <= 20
        && data.text is string
        && data.text.size() <= 1000
        && data.timestamp is timestamp;
    }

    match /users/{userId} {
      allow read, get, list: if true;
      allow create: if isValidId(userId) && isValidUser(incoming());
      allow update: if isValidId(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['lastActive'])
      );
    }

    match /messages/{messageId} {
      allow read, get, list: if true;
      allow create: if isValidId(messageId) && isValidMessage(incoming());
    }
  }
}
